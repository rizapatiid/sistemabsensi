generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id // ID Karyawan
  nama         String
  role         String       // ADMIN or KARYAWAN
  password     String
  status       String       @default("AKTIF") // AKTIF / BLOKIR
  jabatan      String?
  phone        String?
  email        String?
  alamat       String?
  rekeningBank String?
  noRekening   String?
  namaRekening String?
  emailNotifEnabled Boolean @default(true)
  lastSeenAnnouncement DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attendances  Attendance[]
  payrolls     Payroll[]
  pushSubscriptions PushSubscription[]
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Attendance {
  id         String   @id @default(cuid())
  idKaryawan String
  tanggal    DateTime
  waktuMasuk DateTime
  status     String   // HADIR / IZIN
  foto       String?  // Base64 string dari foto selfie
  buktiApp   String?  // Base64 string dari bukti screenshot aplikasi
  alasan     String?  // Alasan jika status IZIN
  user       User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, tanggal])
}

model Payroll {
  id                   String   @id @default(cuid())
  idKaryawan           String
  bulan                Int
  tahun                Int
  tipeGaji             String   @default("BULANAN") // BULANAN / HARIAN
  jumlahAbsen          Int      @default(0)         // Digunakan jika tipeGaji HARIAN
  gajiPokok            Float                        // Nominal per hari atau per bulan
  tunjangan            Float    @default(0)
  keteranganTunjangan  String?
  totalGaji            Float
  
  // Snapshot rekening saat payroll dibuat
  bankSnapshot         String?
  noRekeningSnapshot   String?
  namaRekeningSnapshot String?

  createdAt            DateTime @default(now())
  statusPembayaran     String   @default("DIPROSES") // DIBAYAR / DIPROSES
  user                 User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, bulan, tahun])
}

model Calendar {
  id         String   @id @default(cuid())
  tanggal    DateTime @unique
  keterangan String
  isHoliday  Boolean  @default(false)
}

model Announcement {
  id           String   @id @default(cuid())
  judul        String
  konten       String
  image        String?  // Base64 string dari gambar pengumuman (opsional)
  scheduleDate DateTime? // Tanggal jadwal pengumuman (jika null, langsung tampil)
  tanggal      DateTime @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String?  // Optional: null means global or system broadcast
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: SetNull)
}
