generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String             @id
  nama                 String
  role                 String
  password             String
  status               String             @default("AKTIF")
  jabatan              String?
  phone                String?
  email                String?
  alamat               String?
  rekeningBank         String?
  noRekening           String?
  namaRekening         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  emailNotifEnabled    Boolean            @default(true)
  lastSeenAnnouncement DateTime           @default(now())
  absensiEnabled       Boolean            @default(true)
  attendances          Attendance[]
  receivedMessages     Message[]          @relation("ReceivedMessages")
  sentMessages         Message[]          @relation("SentMessages")
  payrolls             Payroll[]
  pushSubscriptions    PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String   @id @default(cuid())
  idKaryawan String
  tanggal    DateTime
  waktuMasuk DateTime
  status     String
  foto       String?
  buktiApp   String?
  alasan     String?
  user       User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, tanggal])
}

model Payroll {
  id                   String   @id @default(cuid())
  idKaryawan           String
  bulan                Int
  tahun                Int
  tipeGaji             String   @default("BULANAN")
  jumlahAbsen          Int      @default(0)
  gajiPokok            Float
  tunjangan            Float    @default(0)
  keteranganTunjangan  String?
  totalGaji            Float
  bankSnapshot         String?
  noRekeningSnapshot   String?
  namaRekeningSnapshot String?
  createdAt            DateTime @default(now())
  statusPembayaran     String   @default("DIPROSES")
  isRead               Boolean  @default(false)
  user                 User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, bulan, tahun])
}

model Calendar {
  id         String   @id @default(cuid())
  tanggal    DateTime @unique
  keterangan String
  isHoliday  Boolean  @default(false)
}

model Announcement {
  id           String    @id @default(cuid())
  judul        String
  konten       String
  image        String?
  scheduleDate DateTime?
  tanggal      DateTime  @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id                String   @id @default("global")
  maintenance       Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  maintenanceReason String?
  maintenanceUntil  String?
}
