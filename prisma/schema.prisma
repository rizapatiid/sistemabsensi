generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @db.VarChar(191)
  nama                 String             @db.VarChar(255)
  role                 String             @db.VarChar(50)
  password             String             @db.VarChar(255)
  status               String             @default("AKTIF") @db.VarChar(50)
  jabatan              String?            @db.VarChar(255)
  phone                String?            @db.VarChar(50)
  email                String?            @db.VarChar(255)
  alamat               String?            @db.Text
  rekeningBank         String?            @db.VarChar(100)
  noRekening           String?            @db.VarChar(100)
  namaRekening         String?            @db.VarChar(255)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  emailNotifEnabled    Boolean            @default(true)
  lastSeenAnnouncement DateTime           @default(now())
  absensiEnabled       Boolean            @default(true)
  attendances          Attendance[]
  receivedMessages     Message[]          @relation("ReceivedMessages")
  sentMessages         Message[]          @relation("SentMessages")
  payrolls             Payroll[]
  pushSubscriptions    PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid()) @db.VarChar(191)
  userId    String   @db.VarChar(191)
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String   @id @default(cuid()) @db.VarChar(191)
  idKaryawan String   @db.VarChar(191)
  tanggal    DateTime @db.Date
  waktuMasuk DateTime
  status     String   @db.VarChar(50)
  foto       String?  @db.VarChar(500)
  buktiApp   String?  @db.VarChar(500)
  alasan     String?  @db.Text
  user       User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, tanggal])
}

model Payroll {
  id                   String   @id @default(cuid()) @db.VarChar(191)
  idKaryawan           String   @db.VarChar(191)
  bulan                Int
  tahun                Int
  tipeGaji             String   @default("BULANAN") @db.VarChar(50)
  jumlahAbsen          Int      @default(0)
  gajiPokok            Float
  tunjangan            Float    @default(0)
  keteranganTunjangan  String?  @db.Text
  totalGaji            Float
  bankSnapshot         String?  @db.VarChar(100)
  noRekeningSnapshot   String?  @db.VarChar(100)
  namaRekeningSnapshot String?  @db.VarChar(255)
  createdAt            DateTime @default(now())
  statusPembayaran     String   @default("DIPROSES") @db.VarChar(50)
  isRead               Boolean  @default(false)
  user                 User     @relation(fields: [idKaryawan], references: [id], onDelete: Cascade)

  @@unique([idKaryawan, bulan, tahun])
}

model Calendar {
  id         String   @id @default(cuid()) @db.VarChar(191)
  tanggal    DateTime @unique @db.Date
  keterangan String   @db.VarChar(500)
  isHoliday  Boolean  @default(false)
  image      String?  @db.VarChar(500)
}

model Announcement {
  id           String    @id @default(cuid()) @db.VarChar(191)
  judul        String    @db.VarChar(500)
  konten       String    @db.LongText
  image        String?   @db.VarChar(500)
  scheduleDate DateTime?
  tanggal      DateTime  @default(now())
}

model PasswordReset {
  id        String   @id @default(cuid()) @db.VarChar(191)
  email     String   @db.VarChar(255)
  otp       String   @db.VarChar(10)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid()) @db.VarChar(191)
  senderId   String   @db.VarChar(191)
  receiverId String?  @db.VarChar(191)
  content    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id                String   @id @default("global") @db.VarChar(191)
  maintenance       Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  maintenanceReason String?  @db.Text
  maintenanceUntil  String?  @db.VarChar(100)
}
